# Aruba Instant AP connection
ARUBA_HOST=192.168.10.2
ARUBA_SSH_USERNAME=admin
ARUBA_SSH_PASSWORD=changeme

# Web GUI credentials (defaults to SSH credentials if not set)
# ARUBA_WEB_USERNAME=admin
# ARUBA_WEB_PASSWORD=changeme
# ARUBA_WEB_PORT=4343

# Exporter settings
EXPORTER_PORT=9877
COLLECT_INTERVAL=30

# Collector toggles
ENABLE_SSH=true
ENABLE_CGI=true

# Timeouts (seconds)
SSH_TIMEOUT=15
CGI_TIMEOUT=15

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
